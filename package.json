{
  "name": "nest-boilerplate",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc-watch --onSuccess 'node dist/main.js'",
    "postinstall": "git-validator install",
    "style": "git-validator",
    "style:update": "git-validator -u"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "git-validator": "^0.11.2",
    "tsc-watch": "^6.0.4",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.13.1"
}
